# ===========================
# Opera GX Mod — .gitignore
# ===========================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
.venv/
venv/
env/
.env/

# --- Node (if using build tools) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- OS clutter ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Build / packaging ---
*.zip
*.crx
dist/
build/
out/

# --- Generated assets (uncomment if regenerated by scripts) ---
# wallpaper/dark.png
# wallpaper/first_frame.jpeg
# wallpaper/video.webm
# icon_512.png

# --- Large media (uncomment to exclude from repo) ---
# music/*.mp3
# sound/*.mp3
# keyboard/*.wav

# --- Logs & temp ---
*.log
*.tmp
*.temp
.cache/
