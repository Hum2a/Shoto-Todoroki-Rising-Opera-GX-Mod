{
  "manifest_version": 3,
  "name": "Shouto Todoroki Rising",
  "description": "Shouto Todoroki — ice/fire theme, wallpaper, background music, and webmodding.",
  "version": "1.2.1",
  "icons": {
    "512": "icon_512.png"
  },
  "developer": {
    "name": "Humza Butt"
  },
  "mod": {
    "schema_version": 1,
    "license": "license.txt",
    "payload": {
      "wallpaper": {
        "dark": {
          "image": "wallpaper/shoto-todoroki.3840x2160.mp4",
          "first_frame": "wallpaper/first_frame_todoroki.jpeg",
          "text_color": "#E3F2FD",
          "text_shadow": "#0D47A1"
        },
        "light": {
          "image": "wallpaper/shoto-todoroki.3840x2160.mp4",
          "first_frame": "wallpaper/first_frame_todoroki.jpeg",
          "text_color": "#0D47A1",
          "text_shadow": "#E3F2FD"
        }
      },
      "background_music": [
        "music/Todorokis_Counterattack.mp3"
      ],
      "theme": {
        "dark": {
          "gx_accent": { "h": 199, "s": 89, "l": 62 },
          "gx_secondary_base": { "h": 14, "s": 91, "l": 16 }
        },
        "light": {
          "gx_accent": { "h": 199, "s": 70, "l": 45 },
          "gx_secondary_base": { "h": 14, "s": 60, "l": 28 }
        }
      },
      "page_styles": [
        {
          "css": ["webmodding/shoto-rising.css"],
          "matches": ["https://*/*", "http://*/*"]
        },
        {
          "css": ["webmodding/sites-01-google-youtube.css"],
          "matches": [
            "https://www.google.com/*",
            "https://google.com/*",
            "https://mail.google.com/*",
            "https://drive.google.com/*",
            "https://docs.google.com/*",
            "https://calendar.google.com/*",
            "https://maps.google.com/*",
            "https://news.google.com/*",
            "https://play.google.com/*",
            "https://accounts.google.com/*",
            "https://photos.google.com/*",
            "https://meet.google.com/*",
            "https://classroom.google.com/*",
            "https://keep.google.com/*",
            "https://translate.google.com/*",
            "https://contacts.google.com/*",
            "https://www.youtube.com/*",
            "https://youtube.com/*",
            "https://m.youtube.com/*",
            "https://music.youtube.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-02-social.css"],
          "matches": [
            "https://www.reddit.com/*",
            "https://reddit.com/*",
            "https://old.reddit.com/*",
            "https://new.reddit.com/*",
            "https://www.x.com/*",
            "https://x.com/*",
            "https://twitter.com/*",
            "https://www.twitter.com/*",
            "https://mobile.twitter.com/*",
            "https://www.facebook.com/*",
            "https://facebook.com/*",
            "https://m.facebook.com/*",
            "https://web.facebook.com/*",
            "https://www.instagram.com/*",
            "https://instagram.com/*",
            "https://www.tiktok.com/*",
            "https://tiktok.com/*",
            "https://www.discord.com/*",
            "https://discord.com/*",
            "https://www.pinterest.com/*",
            "https://pinterest.com/*",
            "https://www.tumblr.com/*",
            "https://tumblr.com/*",
            "https://www.linkedin.com/*",
            "https://linkedin.com/*",
            "https://www.threads.net/*",
            "https://threads.net/*"
          ]
        },
        {
          "css": ["webmodding/sites-03-dev.css"],
          "matches": [
            "https://github.com/*",
            "https://gist.github.com/*",
            "https://gitlab.com/*",
            "https://stackoverflow.com/*",
            "https://*.stackexchange.com/*",
            "https://stackexchange.com/*",
            "https://superuser.com/*",
            "https://serverfault.com/*",
            "https://askubuntu.com/*",
            "https://math.stackexchange.com/*",
            "https://news.ycombinator.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-04-shopping.css"],
          "matches": [
            "https://www.amazon.com/*",
            "https://amazon.com/*",
            "https://www.amazon.co.uk/*",
            "https://amazon.co.uk/*",
            "https://www.amazon.de/*",
            "https://amazon.de/*",
            "https://www.amazon.ca/*",
            "https://amazon.ca/*",
            "https://www.amazon.co.jp/*",
            "https://amazon.co.jp/*",
            "https://www.amazon.fr/*",
            "https://amazon.fr/*",
