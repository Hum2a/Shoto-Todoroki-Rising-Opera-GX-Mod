            "https://www.ebay.co.uk/*",
            "https://ebay.co.uk/*",
            "https://www.ebay.de/*",
            "https://ebay.de/*",
            "https://www.paypal.com/*",
            "https://paypal.com/*",
            "https://www.apple.com/*",
            "https://apple.com/*"
          ]
        },
        {
          "css": ["webmodding/sites-05-media.css"],
          "matches": [
            "https://www.netflix.com/*",
            "https://netflix.com/*",
            "https://open.spotify.com/*",
            "https://www.spotify.com/*",
            "https://spotify.com/*",
            "https://www.twitch.tv/*",
            "https://twitch.tv/*",
            "https://www.bbc.com/*",
            "https://bbc.com/*",
            "https://www.bbc.co.uk/*",
            "https://bbc.co.uk/*",
            "https://www.cnn.com/*",
            "https://cnn.com/*",
            "https://www.imdb.com/*",
            "https://imdb.com/*",
